# GYBS — set in .env.local (used across hero, nav, footer, intake, pathways, subscriptions)
NEXT_PUBLIC_GYBS_URL=https://get-your-business-score-com.vercel.app
NEXT_PUBLIC_GYBS_BUSINESS_INTAKE_URL=https://get-your-business-score-com.vercel.app/business-intake
NEXT_PUBLIC_GYBS_SUPPLIER_INTAKE_URL=https://get-your-business-score-com.vercel.app/supplier-intake
NEXT_PUBLIC_GYBS_PARTNER_URL=https://get-your-business-score-com.vercel.app/partner
# Optional: score CTA override (defaults to NEXT_PUBLIC_GYBS_URL)
# NEXT_PUBLIC_GYBS_SCORE_URL=

# Contact (optional)
NEXT_PUBLIC_CONTACT_EMAIL=

# Zoho (server-only)
ZOHO_ACCOUNT_BASE=
ZOHO_CREATOR_BASE=
ZOHO_REFRESH_TOKEN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_OWNER_NAME=
ZOHO_APP_LINK_NAME=
ZOHO_GENERAL_FORM_LINK_NAME=
ZOHO_GENERAL_PHONE_FIELD_LINK_NAME=Phone_Number
