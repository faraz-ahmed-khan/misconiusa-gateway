## WORLD-CLASS ANIMATION SYSTEM

Add professional, world-class animations to the entire MisconiUSA.com website. Every element should feel alive, intentional, and smooth. Reference quality: Linear.app, Stripe, and Vercel. Nothing should feel cheap or jarring.

### STEP 1 — INSTALL DEPENDENCIES

Run in terminal:
```bash
npm install framer-motion
npm install @studio-freight/lenis
```

### STEP 2 — SMOOTH SCROLL SETUP

Create a new file: `lib/lenis.ts`
```typescript
import Lenis from '@studio-freight/lenis'

let lenis: Lenis | null = null

export function initLenis() {
  lenis = new Lenis({
    duration: 1.4,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    orientation: 'vertical',
    smoothWheel: true,
    wheelMultiplier: 0.8,
    touchMultiplier: 1.5,
  })

  function raf(time: number) {
    lenis?.raf(time)
    requestAnimationFrame(raf)
  }
  requestAnimationFrame(raf)

  return lenis
}

export function getLenis() {
  return lenis
}
```

In `app/layout.tsx` add:
```typescript
'use client'
import { useEffect } from 'react'
import { initLenis } from '@/lib/lenis'

// Inside the root layout component:
useEffect(() => {
  const lenis = initLenis()
  return () => lenis.destroy()
}, [])
```

